# ============================================================
#  智慧智能体 · 配置文件
#  复制此文件为 config.env，填入你的真实凭据后启动
#  cp config.env.example config.env
# ============================================================

# ───────── 飞书项目平台 ─────────
# 对接飞书项目（project.feishu.cn）的需求管理模块
# 获取：飞书项目 → 开放平台 → 创建插件
FEISHU_PROJECT_PLUGIN_ID=你的PluginID
FEISHU_PROJECT_PLUGIN_SECRET=你的PluginSecret

# 飞书项目用户标识
# 获取：飞书项目网页端 → 左下角双击头像自动复制
FEISHU_PROJECT_USER_KEY=你的UserKey

# 飞书项目空间标识（从 URL 中提取）
PROJECT_SPACE_KEY=aniwonder

# ───────── 飞书 IM 和文档（机器人应用）─────────
# 用于发送消息、创建文档、读取 Wiki
# 获取：https://open.feishu.cn → 创建自建应用
FEISHU_APP_ID=你的AppID
FEISHU_APP_SECRET=你的AppSecret

# ───────── 大模型 API ─────────
# 用于分析 PRD，默认使用 DeepSeek
# 获取：https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=你的DeepSeekKey

# 大模型选择：deepseek 或 anthropic
AI_MODEL=deepseek

# DeepSeek API 地址（不要改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ───────── 运行配置 ─────────
PRD_REVIEW_TIMEOUT_DAYS=3
CHECK_CRON=0 9 * * *
