{
  "rules": [
    {
      "id": "prd-review-timeout",
      "name": "需求评审超时提醒",
      "trigger": { "on": "after_create", "workItemType": "需求" },
      "targetNode": "需求评审",
      "timeoutMinutes": 4320,
      "remind": { "target": "需求提出者", "fallbackUserKey": "" },
      "enabled": true
    },
    {
      "id": "tech-feasibility-timeout",
      "name": "技术可行性确认超时提醒",
      "trigger": { "on": "after_node_completed", "previousNode": "需求评审" },
      "targetNode": "技术可行性确认",
      "timeoutMinutes": 4320,
      "remind": { "target": "节点负责人", "fallbackUserKey": "7649567855117192178" },
      "enabled": true
    },
    {
      "id": "version-headcount-schedule",
      "name": "版本人力盘点+排期通知",
      "description": "版本需求整理完成后，生成人力盘点报告+排期通知",
      "trigger": { "on": "version_node_completed", "workItemType": "版本开发", "completedNode": "版本需求整理" },
      "targetNode": "",
      "timeoutMinutes": 0,
      "remind": { "target": "固定接收人", "fallbackUserKey": "7649567855117192178" },
      "enabled": true
    },
    {
      "id": "version-progress-deviation",
      "name": "版本进度偏离提醒",
      "description": "每天检查版本开发进度，偏离>15%通知PM和SE",
      "trigger": { "on": "version_progress", "workItemType": "版本开发", "deviationThreshold": 15 },
      "targetNode": "",
      "timeoutMinutes": 0,
      "nodeDurations": {
        "版本需求整理": 3,
        "开发": 10,
        "联调": 4,
        "提测": 4,
        "测试": 6,
        "门禁评审": 1,
        "上线": 1
      },
      "remind": { "target": "固定接收人", "fallbackUserKey": "7649567855117192178" },
      "enabled": true
    }
  ]
}
